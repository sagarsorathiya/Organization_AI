# ============================================================
# Organization AI — Environment Configuration
# ============================================================
# Copy this file to backend/.env and fill in your values.
# Lines marked [REQUIRED] must be changed before use.
# See DEPLOYMENT.md for full setup instructions.
# ============================================================

# ---- Application ----
APP_NAME=Organization AI Assistant
APP_ENV=production                    # "development" or "production"
SECRET_KEY=                           # [REQUIRED] python -c "import secrets; print(secrets.token_urlsafe(48))"
CORS_ORIGINS=["https://your-domain.example.com"]
ALLOWED_HOSTS=["your-domain.example.com"]

# ---- Database (PostgreSQL) ----
DATABASE_HOST=localhost               # Use "db" for Docker Compose
DATABASE_PORT=5432
DATABASE_NAME=org_ai
DATABASE_USER=org_ai_user
DATABASE_PASSWORD=                    # [REQUIRED] Strong password (openssl rand -base64 32)
DATABASE_POOL_SIZE=20                 # Increase for more concurrent users (100 for 200+ users)
DATABASE_MAX_OVERFLOW=10              # Burst buffer (50 for 200+ users)

# ---- Active Directory / LDAP ----
AD_ENABLED=false                      # Set true to enable AD/LDAP authentication
AD_SERVER=ldap://your-dc.domain.local
AD_PORT=389
AD_USE_SSL=false                      # Set true + port 636 for LDAPS
AD_DOMAIN=YOURDOMAIN
AD_BASE_DN=DC=yourdomain,DC=local
AD_USER_SEARCH_BASE=OU=Users,DC=yourdomain,DC=local
AD_GROUP_SEARCH_BASE=OU=Groups,DC=yourdomain,DC=local
AD_BIND_USER=                         # Service account DN (optional)
AD_BIND_PASSWORD=                     # Service account password (optional)
AD_ADMIN_GROUP=CN=AI-Admins,OU=Groups,DC=yourdomain,DC=local

# ---- LLM Engine (Ollama) ----
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434   # Use "http://ollama:11434" for Docker Compose
LLM_DEFAULT_MODEL=llama3.1:8b        # Any Ollama model: llama3.1:8b, gemma3:4b, mistral, etc.
LLM_TIMEOUT=300                       # Seconds — increase for CPU-only or large models
LLM_MAX_TOKENS=4096                   # Max tokens per response
LLM_TEMPERATURE=0.7                   # 0.0 = deterministic, 1.0 = creative
LLM_NUM_CTX=4096                      # Context window (tokens). Lower = faster first-token
LLM_NUM_GPU=-1                        # GPU layers: -1=auto-detect, 0=CPU-only, N=specific
LLM_NUM_THREAD=0                      # CPU threads: 0=auto-detect all cores

# ---- Chat Performance ----
CHAT_MAX_CONTEXT_MESSAGES=20          # Max conversation messages sent as context
CHAT_MAX_CONTEXT_CHARS=16000          # Max chars of context (~4K tokens)

# ---- Session / Security ----
SESSION_SECRET=                       # [REQUIRED] python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_EXPIRE_MINUTES=480            # 8 hours
SESSION_COOKIE_NAME=org_ai_session
SESSION_COOKIE_SECURE=true            # Must be true when using HTTPS
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=false              # Enable if exposed to internet
RATE_LIMIT_REQUESTS=60                # Requests per window per user
RATE_LIMIT_WINDOW_SECONDS=60

# ---- File Attachments ----
ATTACHMENTS_ENABLED=true

# ---- Data Retention ----
# Data retention is managed via Admin Panel settings.
# The backend runs an automatic cleanup task on startup
# to enforce configured retention policies.

# ---- Logging ----
LOG_LEVEL=INFO                        # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/app.log

# ---- Admin Groups ----
ADMIN_GROUPS=["AI-Admins","IT-Admins"]

# ---- Local Admin (break-glass account) ----
LOCAL_ADMIN_ENABLED=true
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=                 # [REQUIRED] Strong password for admin access
LOCAL_ADMIN_DISPLAY_NAME=Local Administrator
LOCAL_ADMIN_EMAIL=admin@local

# ---- V2: Feature Flags ----
ENABLE_AGENTS=true                    # AI agent personas with custom system prompts
ENABLE_MEMORY=true                    # Persistent AI memory across conversations
ENABLE_SKILLS=true                    # Prompt chain / workflow engine
ENABLE_RAG=true                       # Knowledge base with local embeddings (RAG)
ENABLE_SCHEDULER=true                 # Background task scheduler (APScheduler)
ENABLE_NOTIFICATIONS=true             # In-app notification system

# ---- V2: Memory ----
MAX_MEMORIES_PER_USER=500
MEMORY_AUTO_EXTRACT=true              # Auto-extract memories from conversations

# ---- V2: Knowledge Base / RAG ----
EMBEDDING_MODEL=nomic-embed-text      # Ollama embedding model for vector search
RAG_CHUNK_SIZE=500                    # Document chunk size (tokens)
RAG_CHUNK_OVERLAP=50                  # Overlap between chunks
RAG_TOP_K=5                           # Number of relevant chunks to retrieve
MAX_KB_DOCUMENTS=1000                 # Max documents per knowledge base

# ---- V2: Scheduler ----
SCHEDULER_TIMEZONE=UTC                # Timezone for cron schedules (e.g., America/New_York)
